generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  alerts    Alert[]
  watchlist Watchlist[]

  @@map("users")
}

model Alert {
  id        String      @id @default(cuid())
  userId    String
  message   String
  severity  String
  status    String      @default("open")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("alerts")
}

model Watchlist {
  id         String   @id @default(cuid())
  userId     String
  label      String
  address    String
  assetCode  String?
  isWallet   Boolean  @default(true)
  isContract Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("watchlists")
}